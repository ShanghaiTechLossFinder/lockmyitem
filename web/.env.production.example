# Copy this file to .env.production before building the web app.
# Do not commit real Publishable Keys or server-side Hunyuan API keys.

VITE_CLOUDBASE_ENV_ID=cloud1-d9gnyuxf5b44b6b92
VITE_CLOUDBASE_FUNCTION_NAME=lostfound
VITE_CLOUDBASE_REGION=ap-shanghai

# CloudBase Web Publishable Key.
# Leave empty only if CloudBase anonymous login is enabled for this environment.
VITE_CLOUDBASE_ACCESS_KEY=

# Legacy aliases are also supported:
# VITE_TCB_ENV_ID=cloud1-d9gnyuxf5b44b6b92
# VITE_TCB_FUNCTION_NAME=lostfound
# VITE_TCB_REGION=ap-shanghai
# VITE_TCB_ACCESS_KEY=

# Optional fallback when you deploy web/api/classify-image.js as a server-side proxy.
# The proxy is locked by default; prefer CloudBase for the public web app.
# Enable this only after the proxy has authentication, origin allow-listing, rate limiting, and image-size limits.
# VITE_ENABLE_MODEL_API_FALLBACK=true
# VITE_MODEL_API_URL=https://lockmyitem.asia/api/classify-image
