page {
  min-height: 100%;
  color: #172026;
  background: #eef3f3;
  font-family: -apple-system, BlinkMacSystemFont, "Helvetica Neue", Helvetica, Arial, sans-serif;
  font-size: 28rpx;
}

view,
text,
button,
input,
textarea {
  box-sizing: border-box;
}

.page {
  min-height: 100vh;
  padding: 24rpx 24rpx 72rpx;
}

.section-title {
  margin: 28rpx 0 16rpx;
  color: #102524;
  font-size: 34rpx;
  font-weight: 800;
}

.muted {
  color: #667085;
}

.card {
  margin-bottom: 20rpx;
  padding: 24rpx;
  background: #ffffff;
  border: 1rpx solid rgba(16, 24, 40, 0.06);
  border-radius: 8rpx;
  box-shadow: 0 8rpx 18rpx rgba(16, 24, 40, 0.045);
}

.button-primary,
.button-secondary,
.button-danger {
  height: 76rpx;
  margin: 0;
  padding: 0 28rpx;
  border-radius: 8rpx;
  font-size: 28rpx;
  line-height: 76rpx;
}

.button-primary {
  color: #ffffff;
  background: #0f766e;
}

.button-secondary {
  color: #0f766e;
  background: #e7f5f2;
}

.button-danger {
  color: #b42318;
  background: #fee4e2;
}

.button-primary::after,
.button-secondary::after,
.button-danger::after {
  border: 0;
}

.tag {
  display: inline-flex;
  align-items: center;
  height: 44rpx;
  margin: 0 12rpx 12rpx 0;
  padding: 0 18rpx;
  color: #475467;
  background: #eef2f5;
  border-radius: 999rpx;
  font-size: 24rpx;
}

.tag.active {
  color: #ffffff;
  background: #0f766e;
}

.empty {
  padding: 72rpx 24rpx;
  color: #6b7280;
  text-align: center;
  background: #ffffff;
  border: 1rpx dashed #cfd6dd;
  border-radius: 8rpx;
}

.surface-hero {
  position: relative;
  min-height: 204rpx;
  margin-bottom: 16rpx;
  padding: 34rpx 30rpx;
  overflow: hidden;
  color: #ffffff;
  background: #123c3a;
  border-radius: 8rpx;
  box-shadow: 0 16rpx 34rpx rgba(18, 60, 58, 0.16);
}

.surface-hero::after {
  position: absolute;
  right: -64rpx;
  bottom: -82rpx;
  width: 220rpx;
  height: 220rpx;
  content: "";
  border: 1rpx solid rgba(255, 255, 255, 0.18);
  border-radius: 50%;
}

.surface-eyebrow,
.surface-title,
.surface-subtitle {
  position: relative;
  z-index: 1;
  display: block;
}

.surface-eyebrow {
  margin-bottom: 10rpx;
  color: rgba(255, 255, 255, 0.68);
  font-size: 20rpx;
  font-weight: 700;
}

.surface-title {
  font-size: 42rpx;
  font-weight: 900;
  line-height: 1.14;
}

.surface-subtitle {
  max-width: 500rpx;
  margin-top: 12rpx;
  color: rgba(255, 255, 255, 0.82);
  font-size: 24rpx;
  line-height: 1.42;
}

.status-pill {
  display: inline-flex;
  align-items: center;
  min-height: 44rpx;
  padding: 0 14rpx;
  color: #0f766e;
  background: #e7f5f2;
  border-radius: 6rpx;
  font-size: 22rpx;
  font-weight: 700;
}
