.messages-hero {
  background: #123c3a;
}

.notice {
  display: block;
}

.notice-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 14rpx;
}

.notice-type {
  display: inline-flex;
  padding: 6rpx 14rpx;
  color: #0f766e;
  background: #e7f5f2;
  border-radius: 6rpx;
  font-size: 24rpx;
  font-weight: 800;
}

.notice-content,
.notice-time {
  display: block;
}

.notice-content {
  color: #172026;
  line-height: 1.5;
}

.notice-time {
  overflow: hidden;
  color: #98a2b3;
  font-size: 22rpx;
  text-align: right;
  text-overflow: ellipsis;
  white-space: nowrap;
}
